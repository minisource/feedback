# Server Configuration
SERVER_PORT=5012
SERVER_HOST=0.0.0.0
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=30s

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=minisource_feedback
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_CONN_IDLE_TIME=10m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth Service Configuration
AUTH_SERVICE_URL=http://localhost:8080
AUTH_CLIENT_ID=feedback-service
AUTH_CLIENT_SECRET=feedback-service-secret-key
AUTH_CACHE_SECONDS=300
AUTH_SKIP_PATHS=/health,/ready,/live

# Storage Service Configuration
STORAGE_SERVICE_URL=http://localhost:5001
STORAGE_MAX_FILE_SIZE=10485760
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# Notifier Service Configuration
NOTIFIER_SERVICE_URL=localhost:9003
NOTIFIER_ENABLED=true

# Comment Service Configuration
COMMENT_SERVICE_URL=http://localhost:5010
COMMENT_TIMEOUT=30

# Feedback Configuration
FEEDBACK_REQUIRE_APPROVAL=false
FEEDBACK_ALLOW_ANONYMOUS=false
FEEDBACK_MAX_TITLE_LENGTH=200
FEEDBACK_MAX_DESCRIPTION_LENGTH=10000
FEEDBACK_MAX_ATTACHMENTS=5
FEEDBACK_TRENDING_WEIGHT_VOTES=1.0
FEEDBACK_TRENDING_WEIGHT_COMMENTS=2.0
FEEDBACK_TRENDING_WEIGHT_VIEWS=0.1
FEEDBACK_TRENDING_DECAY_HOURS=72

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
